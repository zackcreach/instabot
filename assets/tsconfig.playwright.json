{
  "compilerOptions": {
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "playwright/dist",
    "rootDir": "playwright",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["playwright/**/*.ts"],
  "exclude": ["playwright/dist"]
}
