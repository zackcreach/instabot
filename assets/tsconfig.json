{
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "esModuleInterop": true,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "phoenix_live_view": ["../deps/phoenix_live_view/assets/js/types/phoenix_live_view/index.d.ts"],
      "*": ["../deps/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "js/**/*.ts",
    "vendor/**/*.d.ts",
    "vitest.config.ts"
  ]
}
